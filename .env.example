## Public env vars for Expo (safe to commit as examples)
# Backend base URL (you host this server)
# - Android emulator + server on same PC: http://localhost:3000 (the app rewrites to 10.0.2.2 automatically)
# - Physical phone: use your PC LAN IP, e.g. http://192.168.1.50:3000 (not localhost)
EXPO_PUBLIC_API_BASE_URL=https://your-domain.com

## Firebase (client config; still keep it out of source)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

